# ──────────────────────────────────────────
# App
# ──────────────────────────────────────────
APP_ENV=production
APP_NAME=clinic-ai
APP_PORT=8000
LOG_LEVEL=INFO
TIMEZONE=America/Sao_Paulo

# ──────────────────────────────────────────
# Segurança
# ──────────────────────────────────────────
WEBHOOK_SECRET=
INTERNAL_API_TOKEN=

# ──────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# ──────────────────────────────────────────
# OpenRouter
# ──────────────────────────────────────────
OPENROUTER_API_KEY=
DEFAULT_MODEL=openai/gpt-4o
FALLBACK_MODEL=openai/gpt-4o-mini

# ──────────────────────────────────────────
# Uazapi (WhatsApp)
# ──────────────────────────────────────────
UAZAPI_BASE_URL=
UAZAPI_TOKEN=
UAZAPI_INSTANCE=

# ──────────────────────────────────────────
# Doctoralia
# ──────────────────────────────────────────
DOCTORALIA_BASE_URL=
DOCTORALIA_API_KEY=
DOCTORALIA_CLIENT_ID=
DOCTORALIA_CLIENT_SECRET=

# ──────────────────────────────────────────
# Kommo (CRM)
# ──────────────────────────────────────────
KOMMO_BASE_URL=
KOMMO_ACCESS_TOKEN=
KOMMO_PIPELINE_ID=
KOMMO_STAGE_NEW=
KOMMO_STAGE_SCHEDULED=
KOMMO_STAGE_REALIZED=
KOMMO_STAGE_NO_SHOW=

# ──────────────────────────────────────────
# Pagamentos
# ──────────────────────────────────────────
OPENPIX_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ──────────────────────────────────────────
# RabbitMQ
# ──────────────────────────────────────────
RABBITMQ_URL=amqp://user:password@rabbitmq:5672/
RABBITMQ_USER=user
RABBITMQ_PASS=password

# ──────────────────────────────────────────
# Redis
# ──────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ──────────────────────────────────────────
# Slack
# ──────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ──────────────────────────────────────────
# Sentry
# ──────────────────────────────────────────
SENTRY_DSN=

# ──────────────────────────────────────────
# Langfuse
# ──────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
