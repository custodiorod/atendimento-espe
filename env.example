# =========================
# PAYMENTS
# =========================
OPENPIX_API_KEY=
OPENPIX_BASE_URL=
OPENPIX_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
ENABLE_PIX=true
ENABLE_STRIPE=false
PAYMENT_PROVIDER_DEFAULT=openpix

# =========================
# RABBITMQ
# =========================
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_DEFAULT_QUEUE=realtime

# =========================
# REDIS
# =========================
REDIS_URL=redis://redis:6379/0
REDIS_LOCK_DB=1
REDIS_RATE_LIMIT_DB=2
REDIS_CACHE_TTL_SECONDS=300

# =========================
# CELERY
# =========================
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/3
CELERY_TASK_DEFAULT_QUEUE=realtime
CELERY_WORKER_CONCURRENCY=2
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=240

# =========================
# KESTRA
# =========================
KESTRA_BASE_URL=
KESTRA_API_TOKEN=
KESTRA_NAMESPACE=clinic_ai
KESTRA_ENABLED=true

# =========================
# MEDIA / OCR / STT
# =========================
ENABLE_AUDIO_TRANSCRIPTION=true
ENABLE_IMAGE_OCR=true
ENABLE_DOCUMENT_PARSE=true
STT_PROVIDER=
STT_API_KEY=
OCR_PROVIDER=
OCR_API_KEY=
VISION_PROVIDER=
VISION_API_KEY=
MAX_MEDIA_FILE_MB=20

# =========================
# RAG / FAQ
# =========================
ENABLE_RAG=true
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=
VECTOR_STORE=supabase
FAQ_REINDEX_CRON=0 3 * * *
RAG_TOP_K=5
RAG_MIN_SCORE=0.75

# =========================
# MONITORING / ALERTS
# =========================
SLACK_WEBHOOK_URL=
SLACK_ALERTS_CHANNEL=
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.2

# =========================
# RATE LIMIT / ANTI-DUPLICATION
# =========================
IDEMPOTENCY_TTL_SECONDS=3600
WHATSAPP_RATE_LIMIT_PER_MINUTE=20
WHATSAPP_RATE_LIMIT_PER_HOUR=300
CONTACT_MESSAGE_COOLDOWN_SECONDS=3

# =========================
# FEATURE FLAGS
# =========================
ENABLE_REACTIVATION=true
ENABLE_REMINDERS=true
ENABLE_POST_CONSULTA=true
ENABLE_INSURANCE_RAG=true
ENABLE_HUMAN_HANDOFF=true
ENABLE_SQUEEZE_IN_FLOW=true
ENABLE_EMERGENCY_DETECTOR=true
ENABLE_KOMMO_SYNC=true
ENABLE_DOCTORALIA_SYNC=true

# =========================
# IMPORT / LEGACY DATA
# =========================
HIDOCTOR_IMPORT_ENABLED=true
HIDOCTOR_IMPORT_SOURCE=
HIDOCTOR_IMPORT_SCHEDULE=0 2 * * *

# =========================
# OPTIONAL STORAGE
# =========================
STORAGE_PROVIDER=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# =========================
# TEST / DEV
# =========================
DEBUG=false
MOCK_DOCTORALIA=false
MOCK_KOMMO=false
MOCK_PAYMENTS=false
MOCK_UAZAPI=false
